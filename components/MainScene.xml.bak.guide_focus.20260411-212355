        function safeProgramTitle(prog as Object) as String
            title = aaLookupString(prog, "title")
            if title = "" then title = "Untitled Program"
            return title
        end function

        function pad2(n as Integer) as String
            if n < 10 then return "0" + n.ToStr()
            return n.ToStr()
        end function

        function formatMinutesAsClock(total as Integer) as String
            while total < 0
                total = total + 1440
            end while
            total = total mod 1440

            hour24 = Int(total / 60)
            minute = total mod 60

            suffix = "AM"
            if hour24 >= 12 then suffix = "PM"

            hour12 = hour24 mod 12
            if hour12 = 0 then hour12 = 12

            return hour12.ToStr() + ":" + pad2(minute) + " " + suffix
        end function

        function parseProgramStartToLocalDisplay(raw as String) as String
            if raw = invalid or raw = "" then return ""

            if Instr(1, raw, "T") > 0 then
                parts = raw.Tokenize("T")
                if parts.Count() < 2 then return raw

                timePart = parts[1]

                zPos = Instr(1, timePart, "Z")
                if zPos > 0 then timePart = Left(timePart, zPos - 1)

                plusPos = Instr(1, timePart, "+")
                if plusPos > 0 then timePart = Left(timePart, plusPos - 1)

                if Len(timePart) > 8 then timePart = Left(timePart, 8)

                hm = timePart.Tokenize(":")
                if hm.Count() < 2 then return raw

                hour = Val(hm[0])
                minute = Val(hm[1])

                total = (hour * 60) + minute

                ' Eastern Daylight Time
                total = total - 240

                return formatMinutesAsClock(total)
            end if

            return raw
        end function

        function safeProgramStart(prog as Object) as String
            startText = aaLookupString(prog, "start")
            if startText = "" then startText = aaLookupString(prog, "startTime")
            return startText
        end function

        function currentLocalMinutes() as Integer
            dt = CreateObject("roDateTime")
            total = (dt.GetHours() * 60) + dt.GetMinutes()

            ' Roku appears to be reporting UTC here; convert to Eastern Daylight Time
            total = total - 240

            while total < 0
                total = total + 1440
            end while
            total = total mod 1440

            return total
        end function

        function visibleProgramStartIndex(programs as Object) as Integer
            if programs = invalid or programs.Count() = 0 then return 0

            nowMins = currentLocalMinutes()
            best = 0

            for i = 0 to programs.Count() - 1
                p = programs[i]
                startMins = p.Lookup("startMinutesLocal")
                if startMins = invalid then
                    startMins = -1
                end if

                if startMins >= 0 and startMins <= nowMins then
                    best = i
                else if startMins > nowMins then
                    exit for
                end if
            end for

            return best
        end function

        sub updateGuideDisplayByIndex(idx as Integer, channel as Object)
            guideText = ""
            if m.guideLabel = invalid then return

            clearGuideGrid()

            programs = []
            if m.channelPrograms <> invalid and idx >= 0 and idx < m.channelPrograms.Count() then
                programs = m.channelPrograms[idx]
            end if

            progCount = 0
            if programs <> invalid then progCount = programs.Count()

            print "DEBUG: updateGuideDisplayByIndex idx="; idx; " title="; channel.title; " programs="; progCount

            if programs = invalid or progCount = 0 then
                m.infoMeta.text = "No guide data available"
                m.guideLabel.text = "No guide data available"
                return
            end if

            startIdx = visibleProgramStartIndex(programs)

            visible = []
            for vi = startIdx to progCount - 1
                visible.Push(programs[vi])
                if visible.Count() >= 4 then exit for
            end for

            visCount = visible.Count()

            row1 = ""
            row2 = ""
            row3 = ""
            row4 = ""

            if visCount >= 1 then row1 = safeProgramStart(visible[0])
            if visCount >= 2 then row2 = safeProgramStart(visible[1])
            if visCount >= 3 then row3 = safeProgramStart(visible[2])
            if visCount >= 4 then row4 = safeProgramStart(visible[3])

            m.top.findNode("rowLabel1").text = row1
            m.top.findNode("rowLabel2").text = row2
            m.top.findNode("rowLabel3").text = row3
            m.top.findNode("rowLabel4").text = row4

            if visCount >= 1 then setGuideBlock("p11", "p11t", 590, 433, 420, safeProgramTitle(visible[0])) else setGuideBlock("p11", "p11t", 590, 433, 4, "")
            setGuideBlock("p12", "p12t", 1018, 433, 4, "")

            if visCount >= 2 then setGuideBlock("p21", "p21t", 590, 487, 420, safeProgramTitle(visible[1])) else setGuideBlock("p21", "p21t", 590, 487, 4, "")
            setGuideBlock("p22", "p22t", 1018, 487, 4, "")

            if visCount >= 3 then setGuideBlock("p31", "p31t", 590, 541, 420, safeProgramTitle(visible[2])) else setGuideBlock("p31", "p31t", 590, 541, 4, "")
            setGuideBlock("p32", "p32t", 1018, 541, 4, "")

            if visCount >= 4 then
                setGuideBlock("p41", "p41t", 590, 595, 420, safeProgramTitle(visible[3]))
                setGuideBlock("p42", "p42t", 1018, 595, 4, "")
            else
                setGuideBlock("p41", "p41t", 590, 595, 4, "")
                setGuideBlock("p42", "p42t", 1018, 595, 4, "")
            end if

            maxPrograms = 8
            if visCount < maxPrograms then maxPrograms = visCount

            for i = 0 to maxPrograms - 1
                prog = visible[i]
                title = safeProgramTitle(prog)
                time = safeProgramStart(prog)

                if i = 0 then
                    guideText = guideText + "NOW: " + title + chr(10)
                else
                    guideText = guideText + time + " - " + title + chr(10)
                end if
            end for

            m.infoMeta.text = "Live TV Guide"
            m.guideLabel.text = guideText
        end sub

        sub playChannel(channel as Object)
            print "DEBUG: playChannel -> "; channel.title

            if channel = invalid then return
            if channel.url = invalid or channel.url = "" then
                m.infoTitle.text = channel.title
                m.infoMeta.text = "No stream URL available"
                return
            end if

            content = CreateObject("roSGNode", "ContentNode")
            content.url = channel.url
            content.streamformat = "hls"
            m.video.content = content
            m.video.control = "play"

            m.infoTitle.text = channel.title
            m.infoMeta.text = "Playing live stream"
        end sub
