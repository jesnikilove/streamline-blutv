    <script type="text/brightscript"><![CDATA[
        sub init()
            m.video = m.top.findNode("videoPlayer")
            m.categoryList = m.top.findNode("categoryList")
            m.channelList = m.top.findNode("channelList")
            m.favoriteStarBox = m.top.findNode("favoriteStarBox")
            m.favoriteStar = m.top.findNode("favoriteStar")
            m.favoriteStarActive = false
            m.infoTitle = m.top.findNode("infoTitle")
            m.infoMeta = m.top.findNode("infoMeta")
            m.guideLabel = m.top.findNode("guideLabel")

            m.setupOverlay = m.top.findNode("setupOverlay")
            m.setupStatus = m.top.findNode("setupStatus")
            m.deviceCode = m.top.findNode("deviceCodeValue").text
            m.apiBase = "http://192.168.1.81:3001"
            m.activationTask = invalid
            m.loadChannelsTask = invalid
            m.isRefreshing = false
            m.isLoadingChannels = false
            m.channelPrograms = []
            m.filteredChannels = []
            m.selectedCategory = "All"
            m.pendingCategory = "All"
            m.favoriteMap = invalid

            if m.progressTimer <> invalid then
                m.progressTimer.control = "stop"
            end if
            m.loadedChannels = invalid
            m.lastActivation = invalid
            m.bgRefreshTask = invalid
            buildCategories()
            m.categoryList.observeField("itemFocused", "onCategoryFocus")
            m.channelList.observeField("itemFocused", "onChannelFocus")

            m.top.findNode("activateButton").observeField("buttonSelected", "onActivatePressed")
            m.top.findNode("refreshButton").observeField("buttonSelected", "onRefreshPressed")
            m.top.findNode("closeSetupButton").observeField("buttonSelected", "onCloseSetup")

            m.top.findNode("activateButton").setFocus(true)

            ' AUTO START ACTIVATION CHECK
            m.setupOverlay.visible = false

            ensureActivationTask()
            m.isRefreshing = true
            m.setupStatus.text = "Checking activation..."
            m.activationTask.apiBase = m.apiBase
            m.activationTask.deviceCode = m.deviceCode
            m.activationTask.control = "RUN"
        end sub
        sub onCloseSetup()
            m.isRefreshing = false
            m.isLoadingChannels = false
            m.setupOverlay.visible = false
            m.setupStatus.text = ""
            m.categoryList.setFocus(true)
        end sub



        function onKeyEvent(key as String, press as Boolean) as Boolean
            if not press then return false

            if m.setupOverlay <> invalid and m.setupOverlay.visible = true then
                activateBtn = m.top.findNode("activateButton")
                refreshBtn = m.top.findNode("refreshButton")
                closeBtn = m.top.findNode("closeSetupButton")

                if key = "OK" or key = "select" then
                    if activateBtn.hasFocus() then
                        onActivatePressed()
                        return true
                    end if
                    if refreshBtn.hasFocus() then
                        onRefreshPressed()
                        return true
                    end if
                    if closeBtn.hasFocus() then
                        onCloseSetup()
                        return true
                    end if
                end if

                if key = "back" then
                    onCloseSetup()
                    return true
                end if

                if key = "right" then
                    if activateBtn.hasFocus() then
                        refreshBtn.setFocus(true)
                        return true
                    end if
                    if refreshBtn.hasFocus() then
                        closeBtn.setFocus(true)
                        return true
                    end if
                end if

                if key = "left" then
                    if closeBtn.hasFocus() then
                        refreshBtn.setFocus(true)
                        return true
                    end if
                    if refreshBtn.hasFocus() then
                        activateBtn.setFocus(true)
                        return true
                    end if
                end if

                return false
            end if

            if key = "OK" or key = "select" then
                if m.categoryList <> invalid and m.categoryList.hasFocus() then
                    item = m.categoryList.content.getChild(m.categoryList.itemFocused)
                    if item <> invalid then
                        applyCategoryFilter(item.title)
                        m.favoriteStarActive = false
                        updateFavoriteStarForFocus()
                        m.channelList.setFocus(true)
                        return true
                    end if
                end if

                if m.favoriteStarActive then
                    if m.channelList <> invalid then
                        toggleFavoriteByIndex(m.channelList.itemFocused)
                        updateFavoriteStarForFocus()
                        return true
                    end if
                end if
            end if

            if key = "right" then
                if m.categoryList <> invalid and m.categoryList.hasFocus() then
                    m.favoriteStarActive = false
                    updateFavoriteStarForFocus()
                    m.channelList.setFocus(true)
                    return true
                end if

                if m.channelList <> invalid and m.channelList.hasFocus() then
                    m.favoriteStarActive = true
                    updateFavoriteStarForFocus()
                    return true
                end if
            end if

            if key = "left" then
                if m.favoriteStarActive then
                    m.favoriteStarActive = false
                    updateFavoriteStarForFocus()
                    return true
                end if

                if m.channelList <> invalid and m.channelList.hasFocus() then
                    m.categoryList.setFocus(true)
                    return true
                end if
            end if

            return false
        end function
        sub onActivatePressed()
            m.setupStatus.text = "Go to your website and enter code " + m.top.findNode("deviceCodeValue").text
        end sub
        sub onRefreshPressed()
            print "DEBUG: onRefreshPressed"
            if m.isRefreshing then
                m.setupStatus.text = "Still checking activation..."
                return
            end if

            ensureActivationTask()

            m.isRefreshing = true
            m.setupStatus.text = "Checking activation..."

            if m.progressTimer <> invalid then
                m.progressTimer.control = "stop"
            end if

            m.activationTask.apiBase = m.apiBase
            m.activationTask.deviceCode = m.deviceCode
            m.activationTask.control = "RUN"
        end sub




        sub hideSetupFields()
        end sub

        function setupFieldsVisible() as Boolean
            return false
        end function


        sub ensureActivationTask()
            if m.activationTask <> invalid then return

            m.activationTask = CreateObject("roSGNode", "ActivationCheckTask")
            m.activationTask.observeField("responseJson", "onActivationTaskResponse")
            m.activationTask.observeField("errorMessage", "onActivationTaskError")
        end sub
        sub onActivationTaskResponse()
            print "DEBUG: onActivationTaskResponse"
            if m.activationTask = invalid then return

            response = m.activationTask.responseJson
            print "DEBUG: activation response len = "; Len(response)
            if response = invalid or response = "" then return

            m.isRefreshing = false

            data = ParseJson(response)
            if data = invalid or data.ok <> true or data.activation = invalid then
                m.setupStatus.text = "Not activated yet."
                return
            end if

            m.setupStatus.text = "Activated!"
            m.lastActivation = data.activation
            m.isLoadingChannels = true
            startLoadingChannels(data.activation)
        end sub


        sub onActivationTaskError()
            if m.activationTask = invalid then return

            err = m.activationTask.errorMessage
            if err = invalid or err = "" then return

            m.isRefreshing = false
            m.setupStatus.text = err
        end sub


        sub ensureLoadChannelsTask()
            if m.loadChannelsTask <> invalid then return

            m.loadChannelsTask = CreateObject("roSGNode", "LoadChannelsTask")
            m.loadChannelsTask.observeField("responseJson", "onLoadChannelsTaskResponse")
            m.loadChannelsTask.observeField("errorMessage", "onLoadChannelsTaskError")
        end sub

        

        sub onProgressTick()
            if m.progressTimer = invalid then return

            m.progressStep = m.progressStep + 1

            if m.progressStep = 1 then
                m.setupStatus.text = "Connecting to provider..."
            else if m.progressStep = 2 then
                m.setupStatus.text = "Downloading playlist..."
            else if m.progressStep = 3 then
                m.setupStatus.text = "Parsing channels..."
            else if m.progressStep = 4 then
                m.setupStatus.text = "Almost done..."
            else if m.progressStep > 5 then
                m.progressStep = 2
            end if
        end sub

        sub startLoadingChannels(activation as Object)
            print "DEBUG: startLoadingChannels"
            ensureLoadChannelsTask()

            m.setupStatus.text = "Loading cached channels..."

            m.progressTimer = CreateObject("roSGNode", "Timer")
            m.progressTimer.duration = 2
            m.progressTimer.repeat = true
            m.progressTimer.observeField("fire", "onProgressTick")
            m.progressStep = 0
            m.progressTimer.control = "start"

            m.loadChannelsTask.apiBase = m.apiBase
            m.loadChannelsTask.setupType = aaLookupString(activation, "setupType")
            m.loadChannelsTask.host = aaLookupString(activation, "serverUrl")
            m.loadChannelsTask.username = aaLookupString(activation, "username")
            m.loadChannelsTask.password = aaLookupString(activation, "password")
            m.loadChannelsTask.m3uUrl = aaLookupString(activation, "playlistUrl")
            m.loadChannelsTask.epgUrl = aaLookupString(activation, "epgUrl")
            m.loadChannelsTask.forceRefresh = false
            m.loadChannelsTask.control = "RUN"
        end sub

                sub onLoadChannelsTaskResponse()
            print "DEBUG: onLoadChannelsTaskResponse"
            if m.loadChannelsTask = invalid then return
            if m.isLoadingChannels = false then return

            raw = m.loadChannelsTask.responseJson
            print "DEBUG: channels response len = "; Len(raw)
            if raw = invalid or raw = "" then return

            data = ParseJson(raw)
            if data = invalid or data.ok <> true or data.channels = invalid or data.channels.Count() = 0 then
                m.isLoadingChannels = false
                m.setupStatus.text = "No channels returned."
                return
            end if

            ' Load the first 25 real channels for Roku UI
            subset = []
            maxCount = 5000
            for i = 0 to data.channels.Count() - 1
                if i >= maxCount then exit for
                subset.Push(data.channels[i])
            end for

            print "DEBUG: before populateLoadedChannels"
            m.loadedChannels = subset
            populateLoadedChannels()
            print "DEBUG: after populateLoadedChannels"
            clearDemoGuideForLoadedChannels()

            m.isLoadingChannels = false
            m.setupStatus.text = "Loaded first 25 channels."
            m.setupOverlay.visible = false
            m.setupStatus.text = ""
            m.infoMeta.text = "Loaded provider channels"
            m.channelList.jumpToItem = 0
            m.channelList.setFocus(true)
            print "DEBUG: finished onLoadChannelsTaskResponse"

            if m.lastActivation <> invalid then
                startBackgroundRefresh(m.lastActivation)
            end if
        end sub


        sub startBackgroundRefresh(activation as Object)
            if activation = invalid then return
            if m.bgRefreshTask <> invalid then return

            print "DEBUG: startBackgroundRefresh"
            m.bgRefreshTask = CreateObject("roSGNode", "LoadChannelsTask")
            m.bgRefreshTask.observeField("responseJson", "onBackgroundRefreshResponse")
            m.bgRefreshTask.observeField("errorMessage", "onBackgroundRefreshError")

            m.bgRefreshTask.apiBase = m.apiBase
            m.bgRefreshTask.setupType = aaLookupString(activation, "setupType")
            m.bgRefreshTask.host = aaLookupString(activation, "serverUrl")
            m.bgRefreshTask.username = aaLookupString(activation, "username")
            m.bgRefreshTask.password = aaLookupString(activation, "password")
            m.bgRefreshTask.m3uUrl = aaLookupString(activation, "playlistUrl")
            m.bgRefreshTask.epgUrl = aaLookupString(activation, "epgUrl")
            m.bgRefreshTask.forceRefresh = true
            m.bgRefreshTask.control = "RUN"
        end sub

        sub onBackgroundRefreshResponse()
            if m.bgRefreshTask = invalid then return

            raw = m.bgRefreshTask.responseJson
            if raw = invalid or raw = "" then return

            print "DEBUG: onBackgroundRefreshResponse len = "; Len(raw)

            data = ParseJson(raw)
            if data = invalid or data.ok <> true or data.channels = invalid or data.channels.Count() = 0 then
                m.bgRefreshTask = invalid
                return
            end if

            subset = []
            maxCount = 5000
            for i = 0 to data.channels.Count() - 1
                if i >= maxCount then exit for
                subset.Push(data.channels[i])
            end for

            m.loadedChannels = subset
            populateLoadedChannels()
            clearDemoGuideForLoadedChannels()
            m.infoMeta.text = "Channels refreshed in background"
            m.bgRefreshTask = invalid
        end sub

        sub onBackgroundRefreshError()
            if m.bgRefreshTask = invalid then return

            err = m.bgRefreshTask.errorMessage
            print "DEBUG: background refresh error = "; err
            m.bgRefreshTask = invalid
        end sub

        sub onLoadChannelsTaskError()
            print "DEBUG: onLoadChannelsTaskError"
            if m.loadChannelsTask = invalid then return
            if m.isLoadingChannels = false then return

            err = m.loadChannelsTask.errorMessage
            print "DEBUG: channels error = "; err
            if err = invalid or err = "" then return

            m.isLoadingChannels = false
            m.setupStatus.text = err
        end sub

        sub populateLoadedChannels()
            if m.loadedChannels = invalid then return

            rebuildCategoriesFromLoadedChannels()
            applyCategoryFilter(m.selectedCategory)
        end sub

        sub clearDemoGuideForLoadedChannels()
            ' Remove fake guide names completely
            m.top.findNode("rowLabel1").text = ""
            m.top.findNode("rowLabel2").text = ""
            m.top.findNode("rowLabel3").text = ""
            m.top.findNode("rowLabel4").text = ""

            ' Remove fake guide titles completely
            m.top.findNode("p11t").text = ""
            m.top.findNode("p12t").text = ""
            m.top.findNode("p21t").text = ""
            m.top.findNode("p22t").text = ""
            m.top.findNode("p31t").text = ""
            m.top.findNode("p32t").text = ""
            m.top.findNode("p41t").text = ""
            m.top.findNode("p42t").text = ""

            ' Fade out fake guide blocks
            m.top.findNode("p11").color = "0x162a4f44"
            m.top.findNode("p12").color = "0x162a4f44"
            m.top.findNode("p21").color = "0x162a4f44"
            m.top.findNode("p22").color = "0x162a4f44"
            m.top.findNode("p31").color = "0x162a4f44"
            m.top.findNode("p32").color = "0x162a4f44"
            m.top.findNode("p41").color = "0x162a4f44"
            m.top.findNode("p42").color = "0x162a4f44"
        end sub

        function aaLookupString(obj as Dynamic, key as String) as String
            if obj = invalid then return ""
            val = obj.Lookup(key)
            if val = invalid then return ""
            return val
        end function

        sub buildCategories()
            content = CreateObject("roSGNode", "ContentNode")
            addListItem(content, "All")
            addListItem(content, "Favorites")
            m.categoryList.content = content
        end sub

        function getFavoritesSection() as Object
            sec = CreateObject("roRegistrySection", "StreamLineBluTV")
            return sec
        end function

        function loadFavoriteMap() as Object
            sec = getFavoritesSection()
            aa = CreateObject("roAssociativeArray")
            keys = sec.GetKeyList()
            if keys <> invalid then
                for each k in keys
                    aa[k] = true
                end for
            end if
            return aa
        end function

        function channelFavoriteKey(ch as Object) as String
            if ch = invalid then return ""
            key = aaLookupString(ch, "streamUrl")
            if key = "" then key = aaLookupString(ch, "name")
            if key = "" then key = aaLookupString(ch, "number")
            return key
        end function

        function isFavoriteChannel(ch as Object) as Boolean
            if m.favoriteMap = invalid then m.favoriteMap = loadFavoriteMap()
            key = channelFavoriteKey(ch)
            if key = "" then return false
            return m.favoriteMap.Lookup(key) <> invalid
        end function

        sub toggleFavoriteByIndex(idx as Integer)
            if m.filteredChannels = invalid then return
            if idx < 0 or idx >= m.filteredChannels.Count() then return

            if m.favoriteMap = invalid then m.favoriteMap = loadFavoriteMap()

            ch = m.filteredChannels[idx]
            key = channelFavoriteKey(ch)
            if key = "" then return

            sec = getFavoritesSection()

            if m.favoriteMap.Lookup(key) <> invalid then
                sec.Delete(key)
                m.favoriteMap.Delete(key)
                m.infoMeta.text = "Removed from Favorites"
            else
                sec.Write(key, "1")
                sec.Flush()
                m.favoriteMap[key] = true
                m.infoMeta.text = "Added to Favorites"
            end if

            ' If currently viewing Favorites, refresh the filtered list
            if m.selectedCategory = "Favorites" then
                applyCategoryFilter("Favorites")
            else
                ' refresh current channel title decoration if desired later
                item = m.channelList.content.getChild(idx)
                if item <> invalid then
                    updateGuideDisplayByIndex(idx, item)
                end if
            end if
        end sub

        function lookupCategoryName(ch as Object) as String
            if ch = invalid then return ""

            val = aaLookupString(ch, "group")
            if val <> "" then return val

            val = aaLookupString(ch, "groupTitle")
            if val <> "" then return val

            val = aaLookupString(ch, "category")
            if val <> "" then return val

            val = aaLookupString(ch, "categoryName")
            if val <> "" then return val

            return ""
        end function

        sub rebuildCategoriesFromLoadedChannels()
            content = CreateObject("roSGNode", "ContentNode")
            addListItem(content, "All")
            addListItem(content, "Favorites")

            seen = CreateObject("roAssociativeArray")

            if m.loadedChannels <> invalid then
                for each ch in m.loadedChannels
                    cat = lookupCategoryName(ch)
                    if cat <> "" and seen.Lookup(cat) = invalid then
                        seen[cat] = true
                        addListItem(content, cat)
                    end if
                end for
            end if

            m.categoryList.content = content
            m.categoryList.jumpToItem = 0
            m.selectedCategory = "All"
            m.pendingCategory = "All"
        end sub

        sub applyCategoryFilter(category as String)
            if m.loadedChannels = invalid then return

            if category = invalid or category = "" then category = "All"

            if m.favoriteMap = invalid then m.favoriteMap = loadFavoriteMap()
            m.selectedCategory = category
            m.pendingCategory = category

            filtered = []
            for each ch in m.loadedChannels
                cat = lookupCategoryName(ch)

                if category = "All" then
                    filtered.Push(ch)
                else if category = "Favorites" then
                    if isFavoriteChannel(ch) then filtered.Push(ch)
                else if cat = category then
                    filtered.Push(ch)
                end if
            end for

            m.filteredChannels = filtered

            content = CreateObject("roSGNode", "ContentNode")
            m.channelPrograms = []

            for each ch in filtered
                item = content.CreateChild("ContentNode")

                num = aaLookupString(ch, "number")
                nm = aaLookupString(ch, "name")
                url = aaLookupString(ch, "streamUrl")

                if num <> "" then
                    item.title = num + "  " + nm
                else
                    item.title = nm
                end if

                if isFavoriteChannel(ch) then
                    item.title = "★ " + item.title
                end if

                item.addField("url", "string", true)
                item.url = url

                if ch.programs <> invalid then
                    m.channelPrograms.Push(ch.programs)
                else
                    m.channelPrograms.Push([])
                end if
            end for

            m.channelList.content = content

            firstChannel = m.channelList.content.getChild(0)
            if firstChannel <> invalid then
                m.channelList.jumpToItem = 0
                playChannel(firstChannel)
                updateGuideDisplayByIndex(0, firstChannel)
            else
                clearGuideGrid()
                m.guideLabel.text = "No channels in this category"
                m.infoMeta.text = "No channels in this category"
            end if
        end sub

        sub addListItem(parent as Object, title as String)
            item = parent.CreateChild("ContentNode")
            item.title = title
        end sub

        sub updateFavoriteStarForFocus()
            if m.favoriteStar = invalid or m.channelList = invalid or m.favoriteStarBox = invalid then return

            idx = m.channelList.itemFocused
            if idx < 0 then idx = 0

            boxY = 431 + (idx * 52)
            starY = 432 + (idx * 52)

            m.favoriteStarBox.translation = [378, boxY]
            m.favoriteStar.translation = [384, starY]

            isFav = false
            if m.filteredChannels <> invalid and idx >= 0 and idx < m.filteredChannels.Count() then
                isFav = isFavoriteChannel(m.filteredChannels[idx])
            end if

            if m.favoriteStarActive then
                m.favoriteStarBox.color = "0x3E63A8FF"
            else
                m.favoriteStarBox.color = "0x223b73CC"
